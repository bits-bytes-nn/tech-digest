# Pinned by digest for reproducible builds. To update: refresh both the tag and
# the digest together via `docker buildx imagetools inspect
# public.ecr.aws/ubuntu/ubuntu:24.04`.
FROM public.ecr.aws/ubuntu/ubuntu:24.04@sha256:8c10ecc59261c77dd866fa8587f1b9cbf172ad8f1253f0af96eaae0fa390c132

# Ubuntu 24.04 ships Python 3.12, matching the project's requires-python.
ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Seoul \
    LANG=ko_KR.UTF-8 \
    LC_ALL=ko_KR.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        wget gnupg2 ca-certificates \
        xvfb libxi6 \
        locales language-pack-ko fontconfig \
        fonts-nanum* fonts-noto-cjk fonts-noto-color-emoji \
        git && \
    wget -q -O - https://dl-ssl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /usr/share/keyrings/google-chrome-keyring.gpg && \
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome-keyring.gpg] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends google-chrome-stable && \
    locale-gen ko_KR.UTF-8 && \
    ln -sf /usr/bin/python3 /usr/bin/python && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Pin the Chrome binary so HtmlToImageConverter uses it directly and Selenium
# Manager resolves the matching chromedriver without a flaky network download.
ENV CHROME_BINARY=/usr/bin/google-chrome-stable

COPY font-prefer.conf /etc/fonts/conf.d/64-language-selector-prefer.conf
RUN fc-cache -fv

WORKDIR /app

COPY requirements.txt ./
RUN python3 -m pip install --no-cache-dir --break-system-packages -r requirements.txt

COPY . ./

# Run as a non-root user. Chrome already runs with --no-sandbox /
# --disable-dev-shm-usage (see newsletter_renderer._configure_chrome_options),
# so it works without root. On AWS the app writes under /tmp (ROOT_DIR), not
# /app, so the read-only app dir owned by this user is sufficient.
RUN useradd --create-home --uid 10001 appuser && chown -R appuser:appuser /app
USER appuser

CMD ["python3", "main.py"]
